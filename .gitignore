# Dependency directories
node_modules/
jspm_packages/
web_stage/

# Environment variables (Crucial: contains secrets like database passwords & JWT keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Diagnostic reports (for internal use)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp compilation directory (https://code.google.com/p/node-gyp/)
build/

# Mark/Yeoman directory
.lock-wscript

# Optional npm cache directory
.npm

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env

# parcel-cache
.cache
.parcel-cache

# Next.js build images
.next
out

# Nuxt.js build project
.nuxt
dist

# Gatsby files
.cache/
public/

# vuepress build output
.vuepress/dist

# Serverless Webpack directories
.webpack/

